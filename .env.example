# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/engsocial?retryWrites=true&w=majority
DB_NAME=engsocial

# Server
NODE_ENV=production
PORT=3000

# CORS - Comma separated origins (add your Vercel frontend URL)
CORS_ORIGIN=http://localhost:5173,https://your-app.vercel.app

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (optional - for file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
