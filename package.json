{
  "name": "engsocial-be",
  "version": "0.1.0",
  "description": "EngSocial - English Social Learning Platform Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:schema": "mongosh \"$MONGODB_URI\" < database/mongodb-schema.js",
    "db:seed": "mongosh \"$MONGODB_URI\" < database/seed-data.js",
    "db:seed:lessons": "node database/seed-lessons-node.js",
    "db:seed:reading": "node database/seed-reading-lessons.js",
    "db:seed:lessons-page": "node database/seed-lessons.js",
    "db:seed:writing": "node database/seed-writing-lessons.js",
    "db:seed:quests": "node database/seed-quests-node.js",
    "db:seed:all": "node database/seed.js"
  },
  "keywords": [
    "engsocial",
    "english",
    "learning",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.13",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
